{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/o-que-fazemos", "destination": "/index.html" },
    { "source": "/modelos", "destination": "/index.html" },
    { "source": "/camas", "destination": "/index.html" },
    { "source": "/cabeceiras", "destination": "/index.html" },
    { "source": "/puffs-e-banquetas", "destination": "/index.html" },
    { "source": "/projetos", "destination": "/index.html" },
    { "source": "/qualidade", "destination": "/index.html" },
    { "source": "/sob-medida", "destination": "/index.html" },
    { "source": "/sobre", "destination": "/index.html" },
    { "source": "/contato", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        },
        {
          "key": "Permissions-Policy",
          "value": "camera=(), microphone=(), geolocation=()"
        },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self'; base-uri 'self'; connect-src 'self'; font-src 'self' data:; form-action 'none'; frame-ancestors 'none'; img-src 'self' data:; object-src 'none'; script-src 'self'; style-src 'self'; upgrade-insecure-requests"
        },
        {
          "key": "Strict-Transport-Security",
          "value": "max-age=31536000"
        }
      ]
    }
  ]
}
